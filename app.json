{
  "expo": {
    "name": "Close Your Tab",
    "slug": "close-your-tab",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "closeyourtab",
    "userInterfaceStyle": "automatic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.peacockerystudio.closeyourtab",
      "infoPlist": {
        "UIBackgroundModes": [
          "location",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.peacockerystudio.closeyourtab",
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "permissions": [
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to detect when you enter and leave venues.",
          "locationAlwaysPermission": "Allow $(PRODUCT_NAME) to use your location in the background to remind you to close your tab.",
          "locationWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location to find nearby venues.",
          "isBackgroundLocationEnabled": true
        }
      ],
      "expo-font",
      "expo-status-bar",
      "./plugins/without-push-entitlement.js"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "e5e7f3da-6651-4734-95af-f6484327a29e"
      }
    },
    "owner": "simonpeacocks"
  }
}
